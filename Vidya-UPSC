<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vidya - UPSC Executive OS</title>
    <style>
        :root { --primary: #1a73e8; --bg: #f8f9fa; --card: #ffffff; --text: #202124; --success: #34a853; --danger: #d93025; --accent: #fbbc04; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); margin: 0; overflow: hidden; }
        
        .app-container { display: grid; grid-template-columns: 1fr; height: 100vh; }
        @media (min-width: 1024px) {
            .app-container { grid-template-columns: 280px 1fr 350px; }
            .sidebar, .ai-panel { display: flex !important; flex-direction: column; background: white; border: 1px solid #e0e0e0; }
            .mobile-nav { display: none; }
        }

        /* Progress Tracker Styles */
        .tracker-card { background: linear-gradient(135deg, #1a73e8, #0d47a1); color: white; padding: 20px; border-radius: 16px; margin-bottom: 20px; box-shadow: 0 4px 15px rgba(26,115,232,0.3); }
        .progress-bar { background: rgba(255,255,255,0.2); height: 10px; border-radius: 5px; margin-top: 10px; overflow: hidden; }
        .progress-fill { background: var(--accent); height: 100%; width: 0%; transition: width 0.5s; }

        .sidebar { display: none; padding: 20px; overflow-y: auto; }
        .folder { padding: 12px; margin: 5px 0; border-radius: 8px; cursor: pointer; transition: 0.2s; font-weight: 500; }
        .folder:hover { background: #e8f0fe; color: var(--primary); }

        .feed { overflow-y: auto; padding: 20px; padding-bottom: 120px; }
        .card { background: var(--card); border-radius: 16px; padding: 20px; margin-bottom: 15px; border-left: 5px solid var(--primary); box-shadow: 0 4px 10px rgba(0,0,0,0.03); }
        .tag { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 10px; font-weight: 800; background: #e8f0fe; color: var(--primary); margin-bottom: 8px; }

        .ai-panel { display: none; padding: 20px; }
        #chat-box { flex-grow: 1; overflow-y: auto; border: 1px solid #eee; border-radius: 12px; padding: 15px; margin-bottom: 10px; background: #fafafa; font-size: 14px; }
        .chat-input-area { display: flex; gap: 8px; }
        input[type="text"] { flex-grow: 1; padding: 12px; border-radius: 8px; border: 1px solid #ddd; outline: none; }
        .send-btn { background: var(--primary); color: white; border: none; padding: 0 15px; border-radius: 8px; cursor: pointer; font-weight: bold; }

        .mobile-nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; justify-content: space-around; padding: 15px 0; border-top: 1px solid #ddd; z-index: 1000; }
        .camera-btn { background: var(--primary); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: -40px; border: 4px solid var(--bg); box-shadow: 0 5px 15px rgba(26,115,232,0.4); cursor: pointer; }
        
        .overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; z-index: 2000; padding: 20px; box-sizing: border-box; overflow-y: auto; }
        #loader { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.9); z-index:3000; align-items:center; justify-content:center; flex-direction:column; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

<div id="loader">
    <div style="border: 4px solid #f3f3f3; border-top: 4px solid var(--primary); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite;"></div>
    <p style="margin-top:15px; font-weight:bold; color:var(--primary)">Senior is processing...</p>
</div>

<div class="app-container">
    <aside class="sidebar">
        <h2 style="color: var(--primary); margin-top:0;">📚 The Vault</h2>
        <div class="folder" onclick="filterNotes('POLITY')">📑 Polity</div>
        <div class="folder" onclick="filterNotes('ECONOMICS')">📑 Economics</div>
        <div class="folder" onclick="filterNotes('HISTORY')">📑 History</div>
        <div class="folder" onclick="loadNotes()">🔄 All Notes</div>
        <button onclick="syncOffline()" style="margin-top:20px; width:100%; padding:10px; border-radius:8px; border:none; background:var(--success); color:white; cursor:pointer; font-weight:bold;">💾 Offline Sync</button>
    </aside>

    <main class="feed">
        <div class="tracker-card">
            <h3 style="margin:0; font-size: 1rem;">Target: 5 Scans Today</h3>
            <div class="progress-bar"><div class="progress-fill" id="goal-progress"></div></div>
            <p style="margin: 10px 0 0 0; font-size: 0.8rem; opacity: 0.9;" id="goal-text">0/5 pages digitalized</p>
        </div>

        <h2 style="font-size: 1.1rem; color: var(--danger);">📡 Live News Radar</h2>
        <div id="news-feed" style="margin-bottom: 25px;"><p style="font-size:12px; color:#777;">Fetching live updates...</p></div>

        <h2 style="font-size: 1.1rem; color: var(--primary);">📝 Your Vault Feed</h2>
        <div id="notes-container"></div>
    </main>

    <section class="ai-panel">
        <h2 style="color: var(--success); margin-top:0;">🤖 AI Mentor</h2>
        <div id="chat-box">Welcome. Type a doubt or click 'Analyze' on a news item.</div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Ask your mentor...">
            <button class="send-btn" onclick="handleChat()">Go</button>
        </div>
    </section>
</div>

<nav class="mobile-nav">
    <div onclick="location.reload()">🏠</div>
    <div class="camera-btn" onclick="document.getElementById('cam').click()">📸</div>
    <div onclick="showOverlay('ai-overlay')">🤖</div>
</nav>

<div id="ai-overlay" class="overlay">
    <button onclick="hideOverlay('ai-overlay')" style="float:right">Close ✕</button>
    <h2>Mentor Chat</h2>
    <div id="mobile-chat-box" style="height:70%; overflow-y:auto; border:1px solid #eee; padding:15px; margin-bottom:10px; border-radius:10px;"></div>
    <div class="chat-input-area">
        <input type="text" id="mobile-chat-input" placeholder="Type doubt...">
        <button class="send-btn" onclick="handleChat(true)">Ask</button>
    </div>
</div>

<input type="file" id="cam" accept="image/*" capture="environment" style="display:none" onchange="scanImage(this)">

<script>
    const KEY = "AIzaSyDlaJJV8KJiFIvNPJuFlkEkAxbnWMeB9j8";
    let scanCount = parseInt(localStorage.getItem('scans') || 0);

    function updateGoal() {
        const percent = Math.min((scanCount / 5) * 100, 100);
        document.getElementById('goal-progress').style.width = percent + '%';
        document.getElementById('goal-text').innerText = `${scanCount}/5 pages digitalized today`;
    }

    async function handleChat(isMobile = false) {
        const inputId = isMobile ? 'mobile-chat-input' : 'chat-input';
        const boxId = isMobile ? 'mobile-chat-box' : 'chat-box';
        const text = document.getElementById(inputId).value;
        if(!text) return;

        const box = document.getElementById(boxId);
        box.innerHTML += `<p><b>You:</b> ${text}</p>`;
        document.getElementById(inputId).value = '';

        try {
            const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${KEY}`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ contents: [{ parts: [{ text: "Explain this for UPSC Aspirant: " + text }] }] })
            });
            const data = await resp.json();
            box.innerHTML += `<p style="color:var(--primary); background:#f1f3f4; padding:10px; border-radius:8px;"><b>Senior:</b> ${data.candidates[0].content.parts[0].text}</p>`;
            box.scrollTop = box.scrollHeight;
        } catch(e) { alert("Check Connection/API Key"); }
    }

    async function scanImage(input) {
        if(!input.files[0]) return;
        document.getElementById('loader').style.display = 'flex';
        
        const reader = new FileReader();
        reader.readAsDataURL(input.files[0]);
        reader.onload = async () => {
            const base64 = reader.result.split(',')[1];
            try {
                const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${KEY}`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        contents: [{ parts: [
                            {text: "Extract text from this image and summarize it as a UPSC Mains Note. Format: [SUBJECT] | [TITLE] | [SUMMARY]"},
                            {inline_data: {mime_type: "image/jpeg", data: base64}}
                        ]}]
                    })
                });
                const data = await resp.json();
                saveNote(data.candidates[0].content.parts[0].text);
                scanCount++;
                localStorage.setItem('scans', scanCount);
                updateGoal();
            } catch(e) { alert("Scan Failed"); }
            document.getElementById('loader').style.display = 'none';
        };
    }

    function saveNote(raw) {
        const [sub, title, content] = raw.split('|');
        const note = `<div class="card" data-subject="${sub.trim().toUpperCase()}"><span class="tag">${sub}</span><h3>${title}</h3><p>${content}</p></div>`;
        localStorage.setItem('vidya_notes', note + (localStorage.getItem('vidya_notes') || ''));
        loadNotes();
    }

    function loadNotes() {
        document.getElementById('notes-container').innerHTML = localStorage.getItem('vidya_notes') || "No scans yet.";
    }

    function filterNotes(sub) {
        const cards = document.getElementsByClassName('card');
        for(let c of cards) { c.style.display = c.getAttribute('data-subject').includes(sub) ? 'block' : 'none'; }
    }

    async function fetchNews() {
        const resp = await fetch('https://api.rss2json.com/v1/api.json?rss_url=https://www.thehindu.com/news/national/feeder/default.rss');
        const data = await resp.json();
        document.getElementById('news-feed').innerHTML = data.items.slice(0,2).map(i => `
            <div style="background:white; padding:12px; border-radius:10px; margin-bottom:10px; border-left:3px solid var(--danger);">
                <h4 style="margin:0; font-size:14px;">${i.title}</h4>
                <button onclick="document.getElementById('chat-input').value='Analyze this news: ${i.title.replace(/'/g,"")}'; handleChat();" style="border:none; background:none; color:var(--primary); font-size:11px; font-weight:bold; cursor:pointer;">🤖 Analyze</button>
            </div>
        `).join('');
    }

    function syncOffline() {
        const blob = new Blob([localStorage.getItem('vidya_notes')], {type: 'text/plain'});
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'UPSC_Notes.txt'; a.click();
    }

    function showOverlay(id) { document.getElementById(id).style.display = 'block'; }
    function hideOverlay(id) { document.getElementById(id).style.display = 'none'; }

    window.onload = () => { loadNotes(); fetchNews(); updateGoal(); };
</script>
</body>
</html>
